>});</span></span></code></pre>\n\n<div class=\"line-numbers\" aria-hidden=\"true\" style=\"counter-reset:line-number 0\"><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div></div></div></template><template #tab1=\"{ value, isActive }\"><div class=\"language-html line-numbers-mode\" data-ext=\"html\" data-title=\"html\"><button class=\"copy\" title=\"复制代码\" data-copied=\"已复制\"></button><pre class=\"shiki shiki-themes vitesse-light vitesse-dark has-focused-lines vp-code\" v-pre=\"\"><code><span class=\"line\"><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">div</span><span class=\"space\"> </span><span style=\"--shiki-light:#B07D48;--shiki-dark:#BD976A\">id</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">=</span><span style=\"--shiki-light:#B5695977;--shiki-dark:#C98A7D77\">\"</span><span style=\"--shiki-light:#B56959;--shiki-dark:#C98A7D\">app</span><span style=\"--shiki-light:#B5695977;--shiki-dark:#C98A7D77\">\"</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span></span>\n<span class=\"line\"><span class=\"space\"> </span><span class=\"space\"> </span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">h1</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span><span style=\"--shiki-light:#393A34;--shiki-dark:#DBD7CAEE\">姓名：</span><span class=\"space\"> </span><span style=\"--shiki-light:#393A34;--shiki-dark:#DBD7CAEE\">{{ store.name }}</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;/</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">h1</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span></span>\n<span class=\"line\"><span class=\"space\"> </span><span class=\"space\"> </span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">h1</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span><span style=\"--shiki-light:#393A34;--shiki-dark:#DBD7CAEE\">年龄：</span><span class=\"space\"> </span><span style=\"--shiki-light:#393A34;--shiki-dark:#DBD7CAEE\">{{ store.age }}</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;/</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">h1</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span></span>\n<span class=\"line\"><span class=\"space\"> </span><span class=\"space\"> </span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">h1</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span><span style=\"--shiki-light:#393A34;--shiki-dark:#DBD7CAEE\">两年后年龄为:</span><span class=\"space\"> </span><span style=\"--shiki-light:#393A34;--shiki-dark:#DBD7CAEE\">{{store.twoYear}}</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;/</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">h1</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span></span>\n<span class=\"line has-focus\"><span class=\"space\"> </span><span class=\"space\"> </span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">button</span><span class=\"space\"> </span><span style=\"--shiki-light:#B07D48;--shiki-dark:#BD976A\">@click</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">=</span><span style=\"--shiki-light:#B5695977;--shiki-dark:#C98A7D77\">\"</span><span style=\"--shiki-light:#B56959;--shiki-dark:#C98A7D\">store.changeAge()</span><span style=\"--shiki-light:#B5695977;--shiki-dark:#C98A7D77\">\"</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span><span style=\"--shiki-light:#393A34;--shiki-dark:#DBD7CAEE\">年龄+1</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;/</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">button</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span></span>\n<span class=\"line\"><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;/</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">div</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span></span></code></pre>\n\n<div class=\"line-numbers\" aria-hidden=\"true\" style=\"counter-reset:line-number 0\"><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div></div></div></template></CodeTabs>","tagOpen":"<template>","tagClose":"</template>"},"script":null,"scriptSetup":null,"scripts":[],"styles":[],"customBlocks":[]},"content":"从使用的角度来看基本和`Vuex`一样，但是更加简单。\n\n有四个常用的核心概念：`State`、`Getter`、`Mutation`、`Action`。没有了`Mutation`且常用的只有：`State`、`Getters`、`Actions`（同步、异步、都支持）。\n\n## 1.Store\n\n创建一个`js/store.js`文件：在`index.html`中使用：\n:::: code-tabs\n@tab js/store.js\n```js\nconst { defineStore } = Pinia; // 引入 defineStore 函数\n// 定义一个 id 为 counter 的 Store 实例，最终返回一个调用后可获取该实例的函数，并赋值给 useCounterStore\nconst useCounterStore = defineStore(\"counter\", {\n  state: () => ({ // [!code focus:4]\n    age: 10, // 声明一个状态 age，并赋初始值 10\n    name: \"小蓝\", // 声明一个状态 name，并赋初始值“小蓝”\n  }),\n  getters: {},\n  actions: {},\n});\n```\n@tab index.html\n```html :collapsed-lines\n<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width， initial-scale=1.0\" />\n    <title>Document</title>\n    <script src=\"./lib/vue.min.js\"></script>\n    <script src=\"./lib/vueDemi.js\"></script>\n    <script src=\"./lib/pinia.min.js\"></script>\n    <!--  引入store文件 -->\n    <script src=\"./js/store.js\"></script>\n  </head>\n  <body>\n    <div id=\"app\">\n      <h1>姓名: {{ store.name }}</h1>\n      <h1>年龄: {{ store.age }}</h1>\n    </div>\n    <script type=\"module\">\n      const { createApp } = Vue;\n      const { createPinia } = Pinia;\n      const app = Vue.createApp({\n        // 创建 Vue 实例对象 app\n        setup() {\n          const store = useCounterStore(); // 调用 useCounterStore 方法获取 store 对象 counter\n          return {\n            store, // 返回 store 对象，方便 DOM 中使用\n          };\n        },\n      });\n      app.use(createPinia()); // 将 pinia 插件用于 Vue 实例对象 app 中\n      app.mount(\"#app\");\n    </script>\n  </body>\n</html>\n```\n::::\n\n运行效果：\n:::: demo-wrapper no-padding\n::: center\n![20250226235009](https://ccccooh.oss-cn-hangzhou.aliyuncs.com/img/20250226235009.png)\n:::\n::::\n\n## 2.Getters\n\nGetters可以理解为共享的计算属性，假如需要上面的小蓝的两年后年龄就可以使用`Getters`。\n\n:::: code-tabs\n@tab js/store.js\n```js\nconst { defineStore } = Pinia;\n\nconst useCounterStore = defineStore(\"counter\", {\n  state: () => ({\n    age: 10,\n    name: \"小蓝\",\n  }),\n  getters: {  // [!code focus:6]\n    twoYear: (state) => {\n      // 定义一个名为 twoYear 的 getter，接收 state 作为第一个参数\n      return state.age + 2; // 返回基于 state.age 计算后的结果\n    },\n  },\n  actions: {},\n});\n```\n\n@tab index.html\n```html\n<div id=\"app\">\n  <h1>姓名： {{ store.name }}</h1>\n  <h1>年龄： {{ store.age }}</h1>\n  <h1>两年后年龄为: {{store.twoYear}}</h1>  <!-- [!code focus] -->\n</div>\n```\n::::\n\n## 3.Actions\n\n如果想要修改原始数据，就需要使用`Actions`。\n\n:::: code-tabs\n@tab js/store.js\n```js\nconst { defineStore } = Pinia;\nconst useCounterStore = defineStore(\"counter\", {\n  state: () => ({\n    age: 10,\n    name: \"小蓝\",\n  }),\n  getters: {\n    twoYear: (state) => {\n      return state.age + 2;\n    },\n  },\n  actions: {  // [!code focus:6]\n    changeAge() {\n      // 定义一个函数 changeAge 用于修改 age 的值\n      this.age++; // 这里的 this 相当于 store.age\n    },\n  },\n});\n```\n\n@tab index.html\n```html\n<div id=\"app\">\n  <h1>姓名： {{ store.name }}</h1>\n  <h1>年龄： {{ store.age }}</h1>\n  <h1>两年后年龄为: {{store.twoYear}}</h1>\n  <button @click=\"store.changeAge()\">年龄+1</button>  <!-- [!code focus] -->\n</div>\n```\n::::","excerpt":"","includedFiles":[],"tasklistId":0,"title":"","headers":[{"level":2,"title":"1.Store","slug":"_1-store","link":"#_1-store","children":[]},{"level":2,"title":"2.Getters","slug":"_2-getters","link":"#_2-getters","children":[]},{"level":2,"title":"3.Actions","slug":"_3-actions","link":"#_3-actions","children":[]}]}}
