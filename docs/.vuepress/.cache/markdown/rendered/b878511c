-shiki-dark:#4D9375\">script</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span></span>\n<span class=\"line\"><span class=\"space\"> </span><span class=\"space\"> </span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;/</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">body</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span></span>\n<span class=\"line\"><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">&#x3C;/</span><span style=\"--shiki-light:#1E754F;--shiki-dark:#4D9375\">html</span><span style=\"--shiki-light:#999999;--shiki-dark:#666666\">></span></span></code></pre>\n\n<div class=\"line-numbers\" aria-hidden=\"true\" style=\"counter-reset:line-number 0\"><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div><div class=\"line-number\"></div></div><div class=\"collapsed-lines\"></div></div><p>页面效果：</p>\n<div class=\"demo-wrapper no-padding\">\n  <div class=\"demo-head\">\n    <div class=\"demo-ctrl\"><i></i><i></i><i></i></div>\n    \n  </div>\n  <div class=\"demo-container\" >\n<p><img src=\"https://ccccooh.oss-cn-hangzhou.aliyuncs.com/img/20250226184948.png\" alt=\"20250226184948\"></p>\n</div></div><p>点击不同的链接后页面只会局部刷新。</p>\n","tagOpen":"<template>","tagClose":"</template>"},"script":null,"scriptSetup":null,"scripts":[],"styles":[],"customBlocks":[]},"content":"> **Tips**: VueRouter 是Vue官方为单应用专门打造的。\n\n接下来看看如何安装`VueRouter`。\n\n分别有使用`CDN`引入和使用`NPM`安装两种方式。\n\n:::: code-tabs\n@tab CDN\n``` sh\nhttps://unpkg.com/vue-router@2.0.0/dist/vue-router.js\n```\n\n@tab NPM\n``` sh\nnpm install vue-router@4\n```\n::::\n\n这里采用CDN的方式。\n\n其基本的使用方法是：\n- 使用`router-link`组件来导航，通过`to`来跳转指定链接（相当于`<a> </a>`标签）。\n- 使用`router-view`组件定义路由出口，路由匹配到组件将会渲染到此处。\n- 使用`const routes = [{ path, component }]`来定义路由（路径和组件名）。\n- 创建和挂载根实例，在 **new Vue** 中挂载上一步创建的路由实例 `router`。 \n\n首先用命令获取库文件：\n```sh\nwget https://labfile.oss.aliyuncs.com/courses/1262/vue.min.js\nwget https://labfile.oss.aliyuncs.com/courses/10532/vue-router.js\n```\n\n在`index.html`中写入：\n```html :collapsed-lines\n<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Document</title>\n    <script src=\"vue.min.js\"></script>\n    <script src=\"vue-router.js\"></script>\n  </head>\n\n  <body>\n    <div id=\"app\">\n      <h1>路由的使用</h1>\n      <p>\n        <!-- 使用 router-link 组件来导航 -->\n        <router-link to=\"/home\">首页</router-link>\n        <router-link to=\"/hot\">热门</router-link>\n        <router-link to=\"/class\">分类</router-link>\n      </p>\n      <!-- 路由出口 -->\n      <!-- 路由匹配到的组件将渲染在这里 -->\n      <router-view></router-view>\n    </div>\n    <script>\n      const Home = { template: \"<div>首页</div>\" };\n      const Hot = { template: \"<div>热门</div>\" };\n      const Class = { template: \"<div>分类</div>\" };\n\n      // 定义路由\n      const routes = [\n        { path: \"/home\", component: Home },\n        { path: \"/hot\", component: Hot },\n        { path: \"/class\", component: Class },\n      ];\n\n      // 创建 router 实例，然后传 routes 配置\n      const router = new VueRouter({\n        routes,\n      });\n\n      // 创建和挂载根实例\n      const app = new Vue({\n        router,\n      }).$mount(\"#app\");\n    </script>\n  </body>\n</html>\n```\n\n页面效果：\n::: demo-wrapper no-padding\n![20250226184948](https://ccccooh.oss-cn-hangzhou.aliyuncs.com/img/20250226184948.png)\n:::\n\n点击不同的链接后页面只会局部刷新。","excerpt":"","includedFiles":[],"tasklistId":0,"title":"","headers":[]}}
